{
  "name": "project-08-qdrant-vector-db",
  "version": "1.0.0",
  "description": "Express.js + qdrant Vector Search - Multimodal AI & Semantic Search",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "clearAndInstall": "rm -rf node_modules package-lock.json && npm install",
    "seedQuantization": "tsx src/scripts/seedQuantization.ts",
    "seedHybrid": "tsx src/scripts/seedHybrid.ts"
  },
  "keywords": [
    "mongodb",
    "vector-search",
    "embeddings",
    "semantic-search",
    "multimodal",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.18.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.6",
    "mongodb": "^6.3.0",
    "multer": "^2.2.0",
    "sharp": "^0.35.3",
    "undici": "^6.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.1.6"
  },
  "overrides": {
    "sharp": "$sharp",
    "@xenova/transformers": {
      "sharp": "$sharp"
    },
    "undici": "$undici"
  }
}
